# --- Python & uv ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
.pytest_cache/

# --- Ansible & Secrets ---
# NEVER commit the vault password file
.vault_pass
# Encrypted vault file (optional: keep it if you want to share encrypted secrets)
group_vars/all/vault.yml
# Ansible retry files
*.retry
.ansible/*
secrets.yml

# --- Infrastructure & Temp files ---
# Local inventory often contains specific paths
hosts.yml
# Temporary config files generated by Ansible
/tmp/airflow_bootstrap.cfg
/tmp/rabbitmq_bootstrap.conf

# --- Airflow Runtime Data ---
# If you use local folders for volumes, ignore the generated data
logs/
plugins/
# Keep dags/ if you want to version your workflows,
# but ignore local test DAGs if necessary
# dags/test_*.py

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
