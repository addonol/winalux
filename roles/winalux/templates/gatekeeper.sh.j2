#!/bin/sh
# ==============================================================================
# @file roles/winalux/templates/gatekeeper.sh.j2
# @package winalux-core
# @description
#   Secure Access Gatekeeper for isolated developer environments.
#   Handles session token validation and provides a macOS-inspired
#   Welcome Dashboard (MOTD) with real-time resource telemetry.
# ==============================================================================

# Internal configuration injected during deployment
EXPECTED_TOKEN="{{ winalux_volatile_token }}"
PROFILE="{{ winalux_dev.profile | upper }}"
DEV_NAME="{{ winalux_dev.name | upper }}"

# UI Styling: Modern Apple-inspired Palette
BOLD='\033[1m'; WHITE='\033[97m'; GRAY='\033[90m'; BLUE='\033[34m'
GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'; NC='\033[0m'

# --- 1. Automated Authorization Check ---
# Validates session if token is passed via SSH environment (LC_WINALUX_TOKEN).
[ "$LC_WINALUX_TOKEN" = "$EXPECTED_TOKEN" ] && export WINALUX_AUTH=true

# --- 2. Interactive Authorization Challenge ---
# Initiates a secure passcode prompt if not already authorized.
if [ "$WINALUX_AUTH" != "true" ] && [ -t 0 ]; then
    clear
    printf "\n  ${WHITE}${BOLD}W I N A L U X   W O R K S T A T I O N${NC}\n"
    printf "  ${GRAY}Secure rootless development environment${NC}\n\n"
    printf "  Passcode for $DEV_NAME: "
    stty -echo; read -r input_token; stty echo; printf "\n"
    [ "$input_token" = "$EXPECTED_TOKEN" ] && export WINALUX_AUTH=true
fi

# --- 3. Welcome Dashboard & Session Launch ---
if [ "$WINALUX_AUTH" = "true" ]; then
    trap - INT TERM QUIT TSTP
    if [ -t 0 ]; then
        clear
        printf "\n  ${WHITE}${BOLD}W I N A L U X   W O R K S T A T I O N${NC}\n"
        printf "  ${GRAY}Secure rootless development environment${NC}\n\n"

        # --- SECTION: RESOURCE TELEMETRY ---
        # Reads metrics generated by the background monitor service.
        if [ -f "/home/developer/.winalux_metrics" ]; then
            . "/home/developer/.winalux_metrics"
            CPU_INT=$(echo "${CPU_USAGE_PERCENT:-0}" | cut -d. -f1)
            DISK_INT=$(echo "${DISK_USAGE_PERCENT:-0}" | cut -d. -f1)

            draw_mini_bar() {
                v=$1; c=$2; f=$(( v / 10 )); [ $f -gt 10 ] && f=10
                printf "${c}"; i=0; while [ $i -lt $f ]; do printf "■"; i=$((i+1)); done
                printf "${GRAY}"; while [ $i -lt 10 ]; do printf "□"; i=$((i+1)); done
                printf "${NC}"
            }

            printf "  ${BOLD}STATUS${NC}\n"
            printf "  %-12s " "CPU Load:"; draw_mini_bar "$CPU_INT" "$BLUE"; printf " ${CPU_USAGE_PERCENT:-0.0}%%\n"

            # Dynamic storage color based on usage percentage
            D_COL=$GREEN; [ "$DISK_INT" -gt 75 ] && D_COL=$YELLOW; [ "$DISK_INT" -gt 90 ] && D_COL=$RED
            printf "  %-12s " "Storage:"; draw_mini_bar "$DISK_INT" "$D_COL"; printf " ${DISK_USAGE_PERCENT:-0}%% (${DISK_USED_GB:-0}GB / ${DISK_LIMIT_GB:-10}GB)\n"
            printf "  %-12s ${WHITE}%sMB / %sMB${NC}\n" "Memory:" "${RAM_USED_MB:-0}" "${RAM_TOTAL_MB:-0}"
            printf "  %-12s ${GRAY}%s processes${NC}\n\n" "Activity:" "$(ps ax | wc -l)"
        fi

        # --- SECTION: SANDBOX NOTES ---
        # Fixed-width indentation for multi-line alignment.
        printf "  ${BOLD}SANDBOX NOTES${NC}\n"

        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} Files in ${WHITE}/home/developer${NC} are volume-backed.\n" "Persistence"
        printf "                 Redeploying the container will ${GREEN}NOT${NC} delete your work.\n"

        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} This is a ${YELLOW}rootless${NC} system. No sudo access available.\n" "Security"
        printf "                 Direct access outside of the home directory is restricted.\n"

        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} Type ${GREEN}${BOLD}task${NC} to see available development tools.\n\n" "Interface"

        # Timezone-aware synchronization timestamp
        LOCAL_TIME=$(TZ="Europe/Brussels" date '+%H:%M:%S')
        printf "  ${GRAY}Connected as developer | Profile: $PROFILE | $LOCAL_TIME${NC}\n\n"
    fi

    # Final transition: Execute original command (SSH/VS Code) or drop to bash
    if [ -n "$SSH_CONNECTION" ]; then
        exec ${SSH_ORIGINAL_COMMAND:-${SHELL:-/bin/bash.real}}
    else
        # Return control for sourced sessions
        return 0 2>/dev/null || exit 0
    fi
else
    # --- AUTHENTICATION FAILURE ---
    if [ -t 0 ]; then
        printf "\n  ${RED}${BOLD}✕ Authentication failed${NC}\n"
        printf "  ${GRAY}Invalid passcode provided for $DEV_NAME.${NC}\n\n"
        sleep 1.5
    fi
    exit 1
fi
