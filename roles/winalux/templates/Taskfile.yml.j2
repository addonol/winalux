# ==============================================================================
# @file roles/winalux/templates/Taskfile.yml.j2
# @package winalux-core
# @description
#   Main Command Control Center for the Winalux Workstation.
#   Provides automated environment maintenance and real-time telemetry
#   wrapped in a professional macOS-inspired interface.
# ==============================================================================
version: '3'

vars:
  # Metadata injected from Ansible inventory for UI personalization
  W_PROFILE: "{{ winalux_dev.profile | upper }}"
  W_USER: "{{ winalux_dev.name | upper }}"


tasks:
  default:
    desc: "📖 Workspace Status & Sandbox Notes"
    cmds:
      - |
        # Telemetry source generated by the background monitor service
        METRICS="/home/developer/.winalux_metrics"

        # UI Palette: Apple Premium Colors
        BOLD='\033[1m'; WHITE='\033[97m'; GRAY='\033[90m'; BLUE='\033[34m'
        GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'; NC='\033[0m'

        # 1. Dashboard Header
        printf "\n  ${WHITE}${BOLD}W I N A L U X   W O R K S T A T I O N${NC}\n"
        printf "  ${GRAY}Secure rootless development environment${NC}\n\n"

        # 2. STATUS SECTION: Quick Telemetry Overview
        if [ -f "$METRICS" ]; then
          . "$METRICS"

          # Extract integer parts for shell-safe arithmetic in progress bars
          CPU_INT=$(echo "${CPU_USAGE_PERCENT:-0}" | cut -d. -f1)
          DISK_INT=$(echo "${DISK_USAGE_PERCENT:-0}" | cut -d. -f1)

          # Internal helper to render visual mini-bars
          draw_mini_bar() {
              v=$1; c=$2; f=$(( v / 10 )); [ $f -gt 10 ] && f=10
              printf "${c}"; i=0; while [ $i -lt $f ]; do printf "■"; i=$((i+1)); done
              printf "${GRAY}"; while [ $i -lt 10 ]; do printf "□"; i=$((i+1)); done
              printf "${NC}"
          }

          printf "  ${BOLD}STATUS${NC}\n"
          printf "  %-12s " "CPU Load:"; draw_mini_bar "$CPU_INT" "$BLUE"; printf " ${CPU_USAGE_PERCENT:-0.0}%%\n"

          # Dynamic threshold coloring for storage alerts
          D_COL=$GREEN; [ "$DISK_INT" -gt 75 ] && D_COL=$YELLOW; [ "$DISK_INT" -gt 90 ] && D_COL=$RED
          printf "  %-12s " "Storage:"; draw_mini_bar "$DISK_INT" "$D_COL"; printf " ${DISK_USAGE_PERCENT:-0}%% (${DISK_USED_GB:-0}GB / ${DISK_LIMIT_GB:-10}GB)\n"
          printf "  %-12s ${WHITE}%sMB / %sMB${NC}\n" "Memory:" "${RAM_USED_MB:-0}" "${RAM_TOTAL_MB:-0}"
          printf "  %-12s ${GRAY}%s processes${NC}\n\n" "Activity:" "$(ps ax | wc -l)"
        else
          printf "  ${YELLOW}⌛ Metrics engine warming up...${NC}\n\n"
        fi

        # 3. SANDBOX NOTES: Persistence and Security Rules
        # Indentation is strictly aligned for professional multi-line layout
        INDENT="                 "
        printf "  ${BOLD}SANDBOX NOTES${NC}\n"
        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} Files in ${WHITE}/home/developer${NC} are volume-backed.\n" "Persistence"
        printf "${INDENT}${GRAY}Redeploying the container will ${GREEN}NOT${NC}${GRAY} delete your work.${NC}\n"

        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} This is a ${YELLOW}rootless${NC} system. No sudo access available.\n" "Security"
        printf "${INDENT}${GRAY}Direct access outside of the home directory is restricted.${NC}\n"

        printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} Type ${GREEN}${BOLD}task --list${NC} to see all available commands.\n\n" "Interface"

        printf "  ${GRAY}Sync: ${LAST_UPDATE:-N/A} | Profile: {{ winalux_dev.profile | upper }}${NC}\n"
    silent: true

  # --- SECTION: MAINTENANCE ---
  "system:upgrade":
    desc: "Update Python toolchain (UV and PIP) to latest versions"
    cmds:
      - |
        BLUE='\033[34m'; WHITE='\033[97m'; GREEN='\033[32m'; NC='\033[0m'
        printf "\n  ${BLUE}◦${NC} ${WHITE}Upgrading Python toolchain within virtual environment...${NC}\n"
        # Enforces latest pip version using Astral UV's high-speed engine
        uv pip install --upgrade pip
        printf "  ${GREEN}✓ Toolchain is now up to date.${NC}\n"
    silent: true

  # --- SECTION: ADVANCED TELEMETRY ---
  "system:stats":
    desc: "Deep resource inspection (CPU, RAM, Storage, Processes)"
    cmds:
      - |
        METRICS="/home/developer/.winalux_metrics"
        # Apple Premium Palette
        BLUE='\033[34m'; WHITE='\033[97m'; GRAY='\033[90m'; BOLD='\033[1m'; NC='\033[0m'
        GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'

        if [ -f "$METRICS" ]; then
          . "$METRICS"

          printf "\n  ${WHITE}${BOLD}W I N A L U X   S T A T S${NC}\n"
          printf "  ${GRAY}Real-time resource telemetry${NC}\n\n"

          draw_bar() {
              val=$1; col=$2; filled=$(( val / 10 )); [ $filled -gt 10 ] && filled=10
              res="${col}"
              i=0; while [ $i -lt $filled ]; do res="${res}■"; i=$((i+1)); done
              res="${res}${GRAY}"
              while [ $i -lt 10 ]; do res="${res}□"; i=$((i+1)); done
              printf "%b${NC}" "$res"
          }

          # Data Prep
          CPU_INT=$(echo "${CPU_USAGE_PERCENT:-0}" | cut -d. -f1)
          DISK_INT=$(echo "${DISK_USAGE_PERCENT:-0}" | cut -d. -f1)
          PROC_COUNT=$(ps ax | wc -l)

          # 1. CPU: Measures total processor cycles consumed by the container Pod.
          printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} " "CPU Load"
          draw_bar "$CPU_INT" "$BLUE"
          printf " ${BLUE}%s%%${NC}\n" "${CPU_USAGE_PERCENT:-0.0}"
          printf "                 ${GRAY}Total processor cycles consumed by this container.${NC}\n\n"

          # 2. Storage: Tracks Podman volume usage against assigned limits.
          D_COL=$GREEN; [ "$DISK_INT" -gt 75 ] && D_COL=$YELLOW; [ "$DISK_INT" -gt 90 ] && D_COL=$RED
          printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} " "Storage"
          draw_bar "$DISK_INT" "$D_COL"
          printf " %s / %sGB (${DISK_USAGE_PERCENT:-0}%%)\n" "${DISK_USED_GB:-0}GB" "${DISK_LIMIT_GB:-10}"
          printf "                 ${GRAY}Persistent Podman volume usage and quota status.${NC}\n\n"

          # 3. Memory: Resident Set Size (RSS) reflecting true container memory footprint.
          printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} ${WHITE}%sMB${NC}\n" "Memory" "${RAM_USED_MB:-0}"
          printf "                 ${GRAY}Resident Set Size (RSS) of all isolated processes.${NC}\n\n"

          # 4. Processes: Current active threads in the isolated sandbox namespace.
          printf "  ${BLUE}◦${NC} ${WHITE}%-12s${NC} ${WHITE}%s active${NC}\n" "Processes" "$PROC_COUNT"
          printf "                 ${GRAY}Current execution threads within this sandbox namespace.${NC}\n"

          printf "\n  ${GRAY}Sync: $LAST_UPDATE${NC}\n"
        else
          printf "\n  ${BLUE}◦${NC} ${GRAY}Metrics engine warming up...${NC}\n"
        fi
    silent: true
